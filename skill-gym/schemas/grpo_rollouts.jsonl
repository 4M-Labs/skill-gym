{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GRPORolloutGroup",
  "description": "A group of rollouts for a single task, used in Group Relative Policy Optimization. Each line in a .jsonl file is one group containing multiple sampled trajectories ranked by verifier score.",
  "type": "object",
  "required": ["id", "skill_id", "task", "rollouts", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this rollout group.",
      "pattern": "^grpo_[a-f0-9]{12}$"
    },
    "skill_id": {
      "type": "string",
      "description": "Reference to the skill that produced these rollouts."
    },
    "task": {
      "type": "object",
      "required": ["task_id", "instruction", "context"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Stable task identifier within the skill."
        },
        "instruction": {
          "type": "string",
          "description": "Natural language instruction given to the agent."
        },
        "context": {
          "type": "object",
          "description": "Additional context provided to the agent.",
          "additionalProperties": true
        }
      }
    },
    "rollouts": {
      "type": "array",
      "description": "Sampled trajectories for this task, ordered by descending quality score.",
      "minItems": 2,
      "maxItems": 64,
      "items": {
        "type": "object",
        "required": ["rollout_id", "trajectory", "quality", "advantage"],
        "properties": {
          "rollout_id": {
            "type": "string",
            "description": "Unique identifier for this rollout within the group."
          },
          "trajectory": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["role", "content"],
              "properties": {
                "role": {
                  "type": "string",
                  "enum": ["system", "user", "assistant", "tool"]
                },
                "content": { "type": "string" },
                "tool_call": {
                  "type": ["object", "null"],
                  "properties": {
                    "name": { "type": "string" },
                    "arguments": { "type": "object", "additionalProperties": true }
                  }
                },
                "tool_result": {
                  "type": ["object", "null"],
                  "properties": {
                    "success": { "type": "boolean" },
                    "output": { "type": "string" },
                    "error": { "type": ["string", "null"] }
                  }
                }
              }
            }
          },
          "quality": {
            "type": "object",
            "properties": {
              "verdict": {
                "type": "string",
                "enum": ["pass", "fail", "partial"]
              },
              "score": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "checks_passed": { "type": "integer", "minimum": 0 },
              "checks_total": { "type": "integer", "minimum": 1 }
            }
          },
          "advantage": {
            "type": "number",
            "description": "Group-relative advantage: (score - mean(scores)) / std(scores). Positive means above group average."
          },
          "log_prob": {
            "type": ["number", "null"],
            "description": "Log probability of this trajectory under the current policy, if available."
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0,
            "description": "Wall-clock duration of trajectory generation in milliseconds."
          }
        }
      }
    },
    "group_stats": {
      "type": "object",
      "description": "Statistics computed across the rollout group.",
      "properties": {
        "mean_score": {
          "type": "number",
          "description": "Mean quality score across all rollouts."
        },
        "std_score": {
          "type": "number",
          "description": "Standard deviation of quality scores."
        },
        "pass_rate": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Fraction of rollouts with verdict 'pass'."
        },
        "best_rollout_id": {
          "type": "string",
          "description": "ID of the highest-scoring rollout."
        },
        "worst_rollout_id": {
          "type": "string",
          "description": "ID of the lowest-scoring rollout."
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["model_id", "timestamp", "sampling_config"],
      "properties": {
        "model_id": {
          "type": "string",
          "description": "Model that generated these rollouts."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "sampling_config": {
          "type": "object",
          "description": "Parameters used during rollout sampling.",
          "properties": {
            "temperature": { "type": "number", "minimum": 0.0 },
            "top_p": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "num_rollouts": { "type": "integer", "minimum": 2 },
            "max_tokens": { "type": "integer", "minimum": 1 }
          }
        },
        "policy_version": {
          "type": "string",
          "description": "Version of the policy model used for sampling."
        },
        "environment_hash": {
          "type": "string",
          "description": "Hash of the sandbox environment used for execution."
        }
      }
    }
  },
  "additionalProperties": false
}
