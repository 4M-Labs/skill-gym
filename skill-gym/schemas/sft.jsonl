{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SFTTrainingExample",
  "description": "A single supervised fine-tuning example generated from a verified skill environment. Each line in a .jsonl file conforms to this schema.",
  "type": "object",
  "required": ["id", "skill_id", "task", "trajectory", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this training example.",
      "pattern": "^sft_[a-f0-9]{12}$"
    },
    "skill_id": {
      "type": "string",
      "description": "Reference to the skill that produced this example.",
      "examples": ["fastapi-api-builder"]
    },
    "task": {
      "type": "object",
      "required": ["task_id", "instruction", "context"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Stable task identifier within the skill."
        },
        "instruction": {
          "type": "string",
          "description": "Natural language instruction given to the agent."
        },
        "context": {
          "type": "object",
          "description": "Additional context provided to the agent (file contents, schemas, etc.).",
          "additionalProperties": true
        }
      }
    },
    "trajectory": {
      "type": "array",
      "description": "Ordered sequence of agent actions and observations that solve the task.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant", "tool"],
            "description": "Role of the message originator."
          },
          "content": {
            "type": "string",
            "description": "Message content."
          },
          "tool_call": {
            "type": ["object", "null"],
            "description": "Structured tool call if the assistant invoked a tool.",
            "properties": {
              "name": { "type": "string" },
              "arguments": { "type": "object", "additionalProperties": true }
            }
          },
          "tool_result": {
            "type": ["object", "null"],
            "description": "Result returned by the tool if applicable.",
            "properties": {
              "success": { "type": "boolean" },
              "output": { "type": "string" },
              "error": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "description": "Quality signals attached during verification.",
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["pass", "fail", "partial"],
          "description": "Outcome of verifier evaluation."
        },
        "score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Normalized quality score."
        },
        "checks_passed": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of verification checks that passed."
        },
        "checks_total": {
          "type": "integer",
          "minimum": 1,
          "description": "Total number of verification checks run."
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["model_id", "timestamp", "environment"],
      "properties": {
        "model_id": {
          "type": "string",
          "description": "Model that generated this trajectory."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the trajectory was generated."
        },
        "environment": {
          "type": "string",
          "description": "Execution environment identifier (e.g., sandbox hash)."
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Wall-clock duration of the trajectory in milliseconds."
        },
        "token_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total token count across all messages."
        }
      }
    }
  },
  "additionalProperties": false
}
